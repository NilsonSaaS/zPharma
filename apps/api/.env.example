# Port du serveur
PORT=3001

# PostgreSQL — Railway : copier DATABASE_URL depuis le dashboard
# Format : postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://pharmapersonal:secret@localhost:5432/pharmapersonal

# JWT — générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-random-secret-string

# URL du frontend (ton URL Vercel en prod)
FRONTEND_URL=http://localhost:3000

NODE_ENV=development
